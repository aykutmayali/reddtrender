# Reddit API Credentials
# Reddit uygulama tercihlerinden (https://www.reddit.com/prefs/apps) alınır
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# Script app tipi için kullanıcı bilgileri
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# User-Agent (Reddit kurallarına göre benzersiz olmalı)
# Format: <platform>:<app_id>:v<version> (by /u/<reddit_username>)
REDDIT_USER_AGENT=python:reddtrender:v1.0.0 (by /u/your_reddit_username)

# Trend Radar local settings
REDDTRENDER_DATA_DIR=data
REDDTRENDER_REPORT_DIR=reports
REDDTRENDER_KEYWORDS=ai,openai,python,startup,security,privacy,reddit
